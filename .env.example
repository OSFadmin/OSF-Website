# All server-side only — never expose with NEXT_PUBLIC_. Routes stay dormant
# (HTTP 503) until their vars are set.

# ── Contact form → Mailcow SMTP (/api/contact) ──────────────────────────
SMTP_HOST=mail.rmail.online
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# SMTP_SECURE=false           # true for implicit TLS on 465
# CONTACT_TO=contact@opensystems.foundation
# CONTACT_FROM=               # defaults to SMTP_USER

# ── Newsletter signup → Listmonk (/api/subscribe) ───────────────────────
# Tracks email inputs now; portable to Twenty CRM later.
LISTMONK_API_URL=https://listmonk.opensystems.foundation
LISTMONK_API_USER=
LISTMONK_API_TOKEN=
LISTMONK_LIST_ID=
