# Twenty CRM — newsletter subscribe integration (server-side only).
# The /api/subscribe route stays dormant (HTTP 503) until URL + KEY are set.
# Never expose the key to the browser (no NEXT_PUBLIC_ prefix).

TWENTY_API_URL=https://crm.opensystems.foundation
TWENTY_API_KEY=

# Optional — REST path for the custom "Subscribers" object.
# Defaults to /rest/subscribers if unset.
# TWENTY_SUBSCRIBERS_PATH=/rest/subscribers
